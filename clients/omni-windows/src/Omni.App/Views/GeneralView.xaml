<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Omni.App.Views.GeneralView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="18" MaxWidth="640">

            <!-- Incompatibility warning -->
            <controls:InfoBar
                x:Name="IncompatibilityBar"
                IsOpen="{x:Bind ViewModel.IsIncompatible, Mode=OneWay}"
                IsClosable="False"
                Severity="Error"
                Title="Update required"
                Message="{x:Bind ViewModel.LastError, Mode=OneWay}" />

            <!-- Daemon control -->
            <StackPanel x:Name="DaemonControlPanel" Spacing="8" Visibility="Visible">
                <TextBlock Text="Daemon" Style="{StaticResource SubtitleTextBlockStyle}" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Status" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <SymbolIcon x:Name="StatusIcon" Symbol="Help" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Start"
                                    IsEnabled="{x:Bind ViewModel.IsConnected, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                                    Click="OnStartClick" />
                            <Button Content="Stop"
                                    IsEnabled="{x:Bind ViewModel.IsConnected, Mode=OneWay}"
                                    Click="OnStopClick" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Daemon info -->
            <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.IsConnected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="Info" Style="{StaticResource SubtitleTextBlockStyle}" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Input capture" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{x:Bind CaptureStatus, Mode=OneWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="UDP port" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.Port, Mode=OneWay}" />
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Fingerprint" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.Fingerprint, Mode=OneWay}"
                                       IsTextSelectionEnabled="True"
                                       FontFamily="Consolas"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Spacing="6" Visibility="{x:Bind ViewModel.DaemonVersion, Mode=OneWay, Converter={StaticResource EmptyStringToVisibilityConverter}}">
                            <TextBlock Text="Version" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.DaemonVersion, Mode=OneWay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Error message -->
            <controls:InfoBar
                IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                IsClosable="False"
                Severity="Error"
                Title="Something went wrong"
                Message="{x:Bind ViewModel.LastError, Mode=OneWay}" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
